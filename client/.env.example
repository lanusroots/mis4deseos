# URL base de la API del backend (SIN /api al final; los endpoints ya lo incluyen)
VITE_API_URL=http://localhost:5000

# Cloudinary (subida de imágenes desde el panel admin)
# El upload es "unsigned": usá un upload preset restringido a esta carpeta/cuenta.
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
