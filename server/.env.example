PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=

# JWT Secret (generá uno random y seguro, p. ej.: openssl rand -hex 32)
JWT_SECRET=

# JWT Expiration
JWT_EXPIRE=12h

# Frontend URL (para CORS)
FRONTEND_URL=http://localhost:5173

# Cloudinary (para imágenes)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
